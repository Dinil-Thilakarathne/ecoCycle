{
  "name": "custom/php-framework",
  "description": "A lightweight PHP framework with Laravel-like features including routing, dependency injection, middleware, and session management.",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "php",
    "framework",
    "mvc",
    "router",
    "dependency-injection"
  ],
  "authors": [
    {
      "name": "Framework Developer",
      "email": "developer@framework.local"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=7.4",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "phpstan/phpstan": "^1.0",
    "squizlabs/php_codesniffer": "^3.6"
  },
  "autoload": {
    "psr-4": {
      "Core\\": "src/Core/",
      "Controllers\\": "src/Controllers/",
      "Models\\": "src/Models/",
      "Middleware\\": "src/Middleware/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8000 -t public",
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "extra": {
    "framework": {
      "name": "Custom PHP Framework",
      "version": "1.0.0"
    }
  }
}
