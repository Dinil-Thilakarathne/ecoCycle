{
  "name": "custom/php-framework",
  "description": "A lightweight PHP framework with Laravel-like features including routing, dependency injection, middleware, and session management.",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "php",
    "framework",
    "mvc",
    "router",
    "dependency-injection"
  ],
  "authors": [
    {
      "name": "Framework Developer",
      "email": "developer@framework.local"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=7.4",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*"
  },
  "autoload": {
    "psr-4": {
      "Core\\": "src/Core/",
      "EcoCycle\\Core\\": "src/Core/",
      "Controllers\\": "src/Controllers/",
      "Models\\": "src/Models/",
      "Middleware\\": "src/Middleware/",
      "Services\\": "src/Services/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "scripts": {
    "serve": "php -c php-dev.ini -S localhost:8000 -t public",
    "watch": "php watch-files.php",
    "dev": "echo 'Starting development server and file watcher...' && (php -c php-dev.ini -S localhost:8000 -t public > /dev/null 2>&1 &) && php watch-files.php",
    "serve-prod": "php -S localhost:8000 -t public",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up -d --build",
    "docker:up:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f app",
    "docker:logs:all": "docker compose logs -f",
    "docker:shell": "docker compose exec app bash || docker compose exec app sh",
    "docker:db:shell": "docker compose exec db sh -c 'mysql -u$DB_USERNAME -p$DB_PASSWORD $DB_DATABASE'",
    "docker:rebuild": [
      "@docker:down",
      "docker compose build --no-cache app",
      "@docker:up"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "process-timeout": 0
  },
  "extra": {
    "framework": {
      "name": "Custom PHP Framework",
      "version": "1.0.0"
    }
  }
}
