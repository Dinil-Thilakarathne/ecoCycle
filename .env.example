# Environment Configuration
APP_ENV=development
APP_DEBUG=true
APP_KEY=ecocycle_secret_key_change_in_production
APP_URL=http://localhost:8080

# Database Configuration - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=eco_cycle
DB_USERNAME=postgres
DB_PASSWORD=root

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Cache Configuration
CACHE_DRIVER=file

# Mail Configuration
MAIL_DRIVER=smtp
MAIL_FROM_ADDRESS=noreply@ecocycle.com
MAIL_FROM_NAME="EcoCycle"

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_ENCRYPTION=tls
SMTP_TIMEOUT=30

# Security
BCRYPT_ROUNDS=10
HOT_RELOADER_ENABLED=true
HOT_RELOADER_PAGE_AUTO_REFRESH=true

# pgAdmin Configuration (optional)
PGADMIN_EMAIL=admin@ecocycle.local
PGADMIN_PASSWORD=admin123

# PayHere Payment Gateway (Sandbox)
# 1. Register at https://sandbox.payhere.lk/merchant/sign-up
# 2. Go to Side Menu > Integrations to get Merchant ID
# 3. Add your domain/app to get Merchant Secret
PAYHERE_SANDBOX=true
PAYHERE_MERCHANT_ID=your_sandbox_merchant_id
PAYHERE_MERCHANT_SECRET=your_sandbox_merchant_secret
# notify_url MUST be public — use ngrok on localhost: ngrok http 8080
PAYHERE_NOTIFY_URL=https://your-ngrok-url.ngrok.io/api/payhere/notify
PAYHERE_RETURN_URL=http://localhost:8080/company/purchases?payment=success
PAYHERE_CANCEL_URL=http://localhost:8080/company/purchases?payment=cancelled