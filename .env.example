# Copy this file to .env and adjust for your environment

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database (used by docker-compose)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ecocycle
DB_USERNAME=ecocycle
DB_PASSWORD=secret

# Session / Security
SESSION_NAME=ECOSESSID
SESSION_LIFETIME=120
APP_NAME="Digital Waste Management"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eco_cycle
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

PAYMENT_GATEWAY_KEY=your_payment_key
PAYMENT_GATEWAY_SECRET=your_payment_secret

NOTIFICATION_DRIVER=database
