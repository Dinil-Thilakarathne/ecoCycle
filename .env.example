# Environment Configuration
APP_ENV=development
APP_DEBUG=true
APP_KEY=ecocycle_secret_key_change_in_production
APP_URL=http://localhost:8080

# Database Configuration - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=eco_cycle
DB_USERNAME=postgres
DB_PASSWORD=root

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Cache Configuration
CACHE_DRIVER=file

# Mail Configuration (for password reset emails)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ecocycle.com
MAIL_FROM_NAME="EcoCycle"

# Security
BCRYPT_ROUNDS=10
HOT_RELOADER_ENABLED=true
HOT_RELOADER_PAGE_AUTO_REFRESH=true

# pgAdmin Configuration (optional)
PGADMIN_EMAIL=admin@ecocycle.local
PGADMIN_PASSWORD=admin123